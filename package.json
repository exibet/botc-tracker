{
  "name": "botc-tracker",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev --port 3500",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "nuxt typecheck",
    "seed:roles": "tsx scripts/seed-roles.ts",
    "optimize:images": "tsx scripts/optimize-role-images.ts",
    "build": "nuxt build",
    "db:types": "supabase gen types typescript --linked 2>/dev/null > shared/types/database.types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxtjs/supabase": "^2.0.4",
    "@primeuix/themes": "^2.0.3",
    "@primevue/nuxt-module": "^4.5.4",
    "@tailwindcss/vite": "^4.2.2",
    "nuxt": "^4.4.2",
    "primeicons": "^7.0.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.101.1",
    "@vue/language-core": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{ts,vue,mjs}": "eslint --fix"
  }
}
